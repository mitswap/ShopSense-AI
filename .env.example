# Frontend - Supabase (publishable / anon key)
#
# Frontend -> Backend:
# Set this on Vercel so browser requests `/api/*` are sent to your hosted backend.
# Example: https://your-backend.onrender.com
VITE_API_BASE_URL=

VITE_USE_SUPABASE=true
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_... or eyJ...anon

# Server - Supabase secret (service role)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... or eyJ...service_role

# Server - OpenRouter (optional cloud fallback + embeddings)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBED_DIMENSIONS=1536

API_PORT=3001

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# llama3 (large) or llama3.2:1b (lighter, good for demos)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_USE_REASONER=false
OLLAMA_REASONER_MODEL=deepseek-r1:1.5b
OLLAMA_FAST_TIMEOUT_MS=30000
OLLAMA_TRANSLATE_TIMEOUT_MS=12000
OLLAMA_NUM_PREDICT=384
OLLAMA_AUTO_PULL=true
OLLAMA_OPENROUTER_FALLBACK=false
OLLAMA_REASONER_THINK=false
# Force local daemon only (disable HF fallback even if HF_TOKEN is set)
OLLAMA_FORCE_LOCAL=false

# Hugging Face cloud fallback for Ollama-compatible calls
# Create token with "Make calls to Inference Providers" permission.
HF_TOKEN=hf_xxx
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
HF_REASONER_MODEL=Qwen/Qwen2.5-7B-Instruct:fastest
HF_TIMEOUT_MS=45000

RAG_FAST_MODE=true

# RAG cache TTL (ms)
RAG_QUERY_CACHE_TTL_MS=300000
RAG_EMBED_CACHE_TTL_MS=3600000